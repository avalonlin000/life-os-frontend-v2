# ===== Hermes 系统重构 · 环境变量示例 =====
# 使用方法：cp .env.example .env，然后填入实际值
# 设计原则：不给默认值，强制部署时显式配置
# 切换模型只改 LLM 三行，不改代码

# ── 数据库路径（必填） ──
ORIGINAL_DB_PATH=/data/英雄联盟数据库.db
REFACTOR_DB_PATH=/data/refactor_data.db

# ── LLM 配置（必填，设计方案 §6.1） ──
# LLMClient 全走环境变量，不硬编码任何模型名
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# ── 飞书配置（必填，设计方案 §6） ──
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ── 应用配置（可选） ──
APP_ENV=production
DEBUG=0
